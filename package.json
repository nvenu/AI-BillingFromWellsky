    "playwright": "^1.40.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^7.0.11",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
