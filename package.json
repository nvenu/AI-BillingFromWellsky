{
  "name": "kinnser-billing-automation",
  "version": "1.0.0",
  "description": "Automated billing record processing for Kinnser.net",
  "main": "dist/server.js",
  "scripts": {
    "start": "ts-node server.ts",
    "dev": "ts-node kinnser-billing-automation.ts",
    "build": "tsc",
    "prod": "node dist/server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
